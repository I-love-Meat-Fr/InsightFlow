# LLM (OpenAI-compatible or Ollama)
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Ollama: set OPENAI_API_URL=http://localhost:11434/v1 and OPENAI_API_KEY=ollama

# Telegram Bot API (get token from @BotFather; chat_id from getUpdates or your bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# App
LOG_LEVEL=INFO
DATA_DIR=data
LOGS_DIR=logs
